@{
    bool reservaActiva = (bool)(ViewBag.ReservaActiva ?? false);
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}
@if (TempData["Ok"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Ok"]</div>
}

@if (User.Identity!.IsAuthenticated)
{
    <hr />
    <h4>Agendar visita</h4>
    <form asp-action="AgendarVisita" method="post" class="row g-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="inmuebleId" value="@Model.Id" />

        <div class="col-md-4">
            <label class="form-label">Inicio</label>
            <input type="datetime-local" name="fechaInicio" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Fin</label>
            <input type="datetime-local" name="fechaFin" class="form-control" required />
        </div>
        <div class="col-md-12">
            <label class="form-label">Notas</label>
            <textarea name="notas" class="form-control" maxlength="500"></textarea>
        </div>
        <div class="col-12 mt-2">
            <button class="btn btn-primary">Agendar</button>
        </div>
    </form>

    <hr class="my-4" />
    <h4>Reservar</h4>

    @if (!reservaActiva)
    {
        <form asp-action="Reservar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="inmuebleId" value="@Model.Id" />
            <button class="btn btn-warning">Reservar ahora (48h)</button>
        </form>
    }
    else
    {
        <div class="alert alert-info">Este inmueble ya tiene una reserva activa.</div>
    }
}
else
{
    <p class="mt-3">
        <a asp-area="Identity" asp-page="/Account/Login">Inicia sesión</a> para agendar una visita o reservar.
    </p>
}
