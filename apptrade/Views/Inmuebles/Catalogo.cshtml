@model IEnumerable<apptrade.Models.Inmueble>
@using apptrade.Dto
@{
    ViewData["Title"] = "Catálogo";
    var f = (CatalogoFiltroDto)ViewBag.Filtro ?? new CatalogoFiltroDto();
    int total = (int)(ViewBag.Total ?? 0);
    int page = (int)(ViewBag.Page ?? 1);
    int size = (int)(ViewBag.PageSize ?? 9);
    int pages = Math.Max(1, (int)Math.Ceiling(total / (double)size));
}

<h2 class="mb-3">Catálogo</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input name="Ciudad" value="@f.Ciudad" class="form-control" placeholder="Ciudad" />
    </div>

    <div class="col-md-2">
       <div class="col-md-2">
    <select name="Tipo" class="form-select">
        <option value="">Tipo</option>
        @{
            var tipos = Enum.GetValues(typeof(apptrade.Models.TipoInmueble))
                            .Cast<apptrade.Models.TipoInmueble>();
        }
        @foreach (var v in tipos)
        {
            if (f.Tipo.HasValue && f.Tipo.Value == v)
            {
                <option value="@v" selected>@v</option>
            }
            else
            {
                <option value="@v">@v</option>
            }
        }
    </select>
</div>

    </div>

    <div class="col-md-2">
        <input name="PrecioMin" value="@(f.PrecioMin?.ToString() ?? "")" type="number" step="0.01" class="form-control" placeholder="Precio mín" />
    </div>
    <div class="col-md-2">
        <input name="PrecioMax" value="@(f.PrecioMax?.ToString() ?? "")" type="number" step="0.01" class="form-control" placeholder="Precio máx" />
    </div>
    <div class="col-md-2">
        <input name="DormitoriosMin" value="@(f.DormitoriosMin?.ToString() ?? "")" type="number" class="form-control" placeholder="Dormitorios ≥" />
    </div>
    <div class="col-md-1 d-grid">
        <button class="btn btn-primary">Filtrar</button>
    </div>
</form>

<partial name="_ValidationSummary" />

@if (!Model.Any())
{
    <div class="alert alert-info">No hay inmuebles que coincidan con los filtros.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var i in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <img src="@i.Imagen" class="card-img-top" alt="@i.Titulo" />
                    <div class="card-body">
                        <h5 class="card-title">@i.Titulo</h5>
                        <p class="card-text">
                            @i.Ciudad • @i.MetrosCuadrados m² • S/ @i.Precio
                        </p>
                        <a class="btn btn-primary" asp-action="Detalle" asp-route-id="@i.Id">Ver detalle</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (pages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int p = 1; p <= pages; p++)
                {
                    <li class="page-item @(p == page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Catalogo"
                           asp-route-Ciudad="@f.Ciudad"
                           asp-route-Tipo="@f.Tipo"
                           asp-route-PrecioMin="@f.PrecioMin"
                           asp-route-PrecioMax="@f.PrecioMax"
                           asp-route-DormitoriosMin="@f.DormitoriosMin"
                           asp-route-Page="@p"
                           asp-route-PageSize="@size">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
